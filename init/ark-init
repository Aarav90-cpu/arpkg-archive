#!/bin/sh
# =============================================================================
#  ARK OS — ark-init
#  Minimal PID 1 init system. No systemd. No sysvinit. Just speed.
#
#  Boot sequence:
#   1. Mount essential virtual filesystems
#   2. Set hostname and system clock
#   3. Bring up loopback
#   4. Load kernel modules from /etc/modules-load.d/
#   5. Run /etc/ark/init.d/* hooks (sorted, sequential)
#   6. Start DHCP on first Ethernet interface
#   7. Set CPU governor
#   8. Spawn getty on tty1
#   9. Launch Hyprland on tty2
#  10. Reap zombies forever (PID 1 duty)
#
#  Shutdown (SIGTERM/SIGINT → PID 1):
#   Kill all → sync → unmount → poweroff/reboot
# =============================================================================

if [ -t 1 ]; then
    G='\033[0;32m' Y='\033[1;33m' R='\033[0;31m'
    B='\033[0;34m' C='\033[0;36m' N='\033[0m' BOLD='\033[1m'
else
    G='' Y='' R='' B='' C='' N='' BOLD=''
fi

log()  { printf "${B}[init]${N} %s\n" "$*"; }
ok()   { printf "${G}[  OK  ]${N} %s\n" "$*"; }
warn() { printf "${Y}[ WARN ]${N} %s\n" "$*" >&2; }
fail() { printf "${R}[ FAIL ]${N} %s\n" "$*" >&2; }

# Banner
printf "${BOLD}${C}"
printf '   ___   ____  __ __      ___  _____\n'
printf '  / _ | / __ \/ //_/     / _ \/ ___/\n'
printf ' / __ |/ /_/ / ,<       / // /\__ \ \n'
printf '/_/ |_|\____/_/|_|  v1  /____/____/ \n'
printf "${N}  ${B}Boot. Survive. Build.${N}\n\n"

# ── 1: Virtual filesystems ──────────────────────────────────────────────────
log "Mounting virtual filesystems..."
mount -t proc     proc     /proc    -o nosuid,noexec,nodev     2>/dev/null
mount -t sysfs    sysfs    /sys     -o nosuid,noexec,nodev     2>/dev/null
mount -t devtmpfs devtmpfs /dev     -o nosuid,mode=0755        2>/dev/null
mount -t devpts   devpts   /dev/pts -o nosuid,noexec,mode=0620 2>/dev/null
mount -t tmpfs    tmpfs    /run     -o nosuid,nodev,mode=0755  2>/dev/null
mount -t tmpfs    tmpfs    /tmp     -o nosuid,nodev,mode=1777  2>/dev/null
mount -t cgroup2  cgroup2  /sys/fs/cgroup -o nosuid,noexec,nodev 2>/dev/null \
    && ok "cgroup2" || warn "cgroup2 unavailable (Waydroid needs this)"
ok "Virtual filesystems mounted."

# ── 2: /dev population ──────────────────────────────────────────────────────
if command -v mdev >/dev/null 2>&1; then
    echo /sbin/mdev > /proc/sys/kernel/hotplug 2>/dev/null || true
    mdev -s && ok "mdev: /dev populated."
fi

# ── 3: Remount root rw ──────────────────────────────────────────────────────
mount -o remount,rw / 2>/dev/null && ok "Root: read-write." \
    || warn "Could not remount root rw."

# ── 4: Hostname ─────────────────────────────────────────────────────────────
HOSTNAME="ark"
[ -f /etc/hostname ] && HOSTNAME=$(tr -d '[:space:]' < /etc/hostname)
echo "$HOSTNAME" > /proc/sys/kernel/hostname
ok "Hostname: $HOSTNAME"

# ── 5: Hardware clock ───────────────────────────────────────────────────────
command -v hwclock >/dev/null 2>&1 \
    && hwclock --hctosys --utc 2>/dev/null \
    && ok "Hardware clock synced."

# ── 6: Loopback ─────────────────────────────────────────────────────────────
ip link set lo up 2>/dev/null || ifconfig lo up 2>/dev/null || true
ok "Loopback: up."

# ── 7: Kernel modules ───────────────────────────────────────────────────────
for modfile in /etc/modules-load.d/*.conf; do
    [ -f "$modfile" ] || continue
    while IFS= read -r mod; do
        case "$mod" in ''|\#*) continue ;; esac
        modprobe "$mod" 2>/dev/null && ok "Module: $mod" \
            || warn "Module not found: $mod"
    done < "$modfile"
done

# ── 8: Init hooks ───────────────────────────────────────────────────────────
if [ -d /etc/ark/init.d ]; then
    for hook in $(ls /etc/ark/init.d/*.sh 2>/dev/null | sort); do
        [ -x "$hook" ] || continue
        name=$(basename "$hook")
        log "Hook: $name"
        "$hook" && ok "Hook OK: $name" || warn "Hook non-zero: $name"
    done
fi

# ── 9: DHCP on first Ethernet ───────────────────────────────────────────────
log "Network: scanning interfaces..."
for iface in $(ls /sys/class/net/ 2>/dev/null); do
    [ "$iface" = "lo" ] && continue
    type_f="/sys/class/net/${iface}/type"
    [ -f "$type_f" ] || continue
    [ "$(cat "$type_f")" = "1" ] || continue   # ARPHRD_ETHER only
    ip link set "$iface" up 2>/dev/null || true
    udhcpc -i "$iface" -n -q -t 5 \
           -s /etc/udhcpc/default.script 2>/dev/null \
        && ok "DHCP: $iface acquired address" && break \
        || warn "DHCP: $iface failed"
done

# ── 10: CPU governor ────────────────────────────────────────────────────────
AC=$(cat /sys/class/power_supply/AC*/online 2>/dev/null | head -1)
GOVERNOR="schedutil"
[ "$AC" = "1" ] && GOVERNOR="performance"
for gf in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    echo "$GOVERNOR" > "$gf" 2>/dev/null || true
done
ok "CPU governor: $GOVERNOR"

# ── 11: Suppress printk noise (unless verbose boot) ─────────────────────────
if [ ! -f /etc/ark/verbose-boot ]; then
    echo "1 4 1 7" > /proc/sys/kernel/printk 2>/dev/null || true
fi

# ── 12: getty on tty1 ───────────────────────────────────────────────────────
setsid getty -L tty1 115200 vt100 &
ok "getty: tty1 spawned."

# ── 13: Hyprland on tty2 ────────────────────────────────────────────────────
ARK_USER=$(getent passwd 1000 2>/dev/null | cut -d: -f1)
if [ -n "$ARK_USER" ]; then
    ok "Desktop: launching Hyprland for $ARK_USER on tty2..."
    openvt -c 2 -s -w -- \
        su - "$ARK_USER" -c \
        'XDG_RUNTIME_DIR=/run/user/1000
         WAYLAND_DISPLAY=wayland-1
         WLR_NO_HARDWARE_CURSORS=0
         exec Hyprland' &
    ok "Hyprland: PID $!"
else
    warn "No UID-1000 user — desktop will not autostart."
fi

ok "ARK OS boot complete."
printf "\n"

# ── Shutdown handler ────────────────────────────────────────────────────────
_shutdown() {
    action="${1:-poweroff}"
    printf "\n${Y}[init]${N} Shutdown: %s\n" "$action"
    kill -TERM -1 2>/dev/null; sleep 2; kill -KILL -1 2>/dev/null
    sync
    umount -a -r 2>/dev/null || true
    sync
    case "$action" in
        reboot)   reboot  -f ;;
        poweroff) poweroff -f ;;
        *)        halt    -f ;;
    esac
}

trap '_shutdown poweroff' TERM
trap '_shutdown reboot'   INT
trap '_shutdown halt'     HUP

# ── PID 1 zombie reaper ─────────────────────────────────────────────────────
while true; do
    wait
done
