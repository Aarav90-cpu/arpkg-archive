# ARKBUILD — gtk4
# GTK4 toolkit — required by Waybar, nwg-dock, and the ARK OS setup greeter
PKG_NAME="gtk4"
PKG_VERSION="4.14.4"
SOURCE_URL="https://gitlab.gnome.org/GNOME/gtk.git"
DEPENDENCIES="musl pipewire"

build() {
    git clone --depth 1 --branch "$PKG_VERSION" "$SOURCE_URL" gtk
    cd gtk
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Doptimization=s \
        -Dintrospection=disabled \
        -Ddocumentation=false \
        -Dtests=false \
        -Dexamples=false \
        -Dx11-backend=false \
        -Dwayland-backend=true \
        -Dbuild-demos=false \
        -Dbuild-tests=false \
        -Dbuild-testsuite=false
    ninja -C build -j$(nproc)
    DESTDIR="$PKG_ROOT" ninja -C build install
}
